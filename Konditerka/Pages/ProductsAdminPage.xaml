<Page x:Class="Konditerka.Pages.ProductsAdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="400" d:DesignWidth="760"
      Title="ProductsAdminPage">

    <Grid Background="#FF420046" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="ProductsGrid" Grid.Row="0" Margin="0,0,0,10" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionChanged="ProductsGrid_SelectionChanged" FontFamily="Arial Black">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding IdCatalog}" Width="60"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Product}" Width="*"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Categories.NameCategory}" Width="150"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="100"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Descripton}" Width="200"/>
                <DataGridTextColumn Header="Изображение" Binding="{Binding PhotoPath}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" Margin="0,0,10,0">
                <TextBlock Text="Название десерта" Foreground="#FF82DBFF" FontFamily="Arial Black"/>
                <TextBox x:Name="ProductNameBox" Height="28" Margin="0,4,0,8" FontFamily="Arial Black" TabIndex="100"/>

                <TextBlock Text="Категория" Foreground="#FF82DBFF" FontFamily="Arial Black"/>
                <ComboBox x:Name="CategoryBox" Height="28" Margin="0,4,0,8" DisplayMemberPath="NameCategory" SelectedValuePath="IdCategory" FontFamily="Arial Black"/>

                <TextBlock Text="Цена" Foreground="#FF82DBFF" FontFamily="Arial Black"/>
                <TextBox x:Name="PriceBox" Height="28" Margin="0,4,0,8" FontFamily="Arial Black" TabIndex="50"/>

                <TextBlock Text="Описание" Foreground="#FF82DBFF" FontFamily="Arial Black"/>
                <TextBox x:Name="DescriptionBox" Height="60" Margin="0,4,0,8" TextWrapping="Wrap" AcceptsReturn="True" FontFamily="Arial Black" TabIndex="1000"/>

                <TextBlock Text="Путь к изображению" Foreground="#FF82DBFF" FontFamily="Arial Black"/>
                <TextBox x:Name="PhotoPathBox" Height="28" Margin="0,4,0,8" FontFamily="Arial Black" GotFocus="PhotoPathBox_GotFocus" TabIndex="100"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,10,0">
                <Button Content="Добавить" Width="150" Height="34" Margin="0,0,0,8" Click="AddButton_Click"
                        FontFamily="Arial Black" Foreground="Black" Background="#FFE0C14D"/>
                <Button Content="Сохранить" Width="150" Height="34" Margin="0,0,0,8" Click="EditButton_Click"
                        FontFamily="Arial Black" Foreground="Black" Background="#FFE0C14D"/>
                <Button Content="Удалить" Width="150" Height="34" Margin="0,0,0,8" Click="DeleteButton_Click"
                        FontFamily="Arial Black" Foreground="Black" Background="#FFE0C14D"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
