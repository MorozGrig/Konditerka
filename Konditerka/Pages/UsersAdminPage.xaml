<Page x:Class="Konditerka.Pages.UsersAdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" d:DesignHeight="400" d:DesignWidth="1000"
      Title="UsersAdminPage">
    <Grid Background="#FF420046">
        <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <DataGrid x:Name="UsersGrid" AutoGenerateColumns="False" SelectionChanged="UsersGrid_SelectionChanged" FontFamily="Arial Black" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding IdUser}" Width="70"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding NameUser}" Width="*"/>
                <DataGridTextColumn Header="Пароль" Binding="{Binding Password}" Width="150"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding Roles.NameRole}" Width="150"/>
                <DataGridTextColumn Header="Город" Binding="{Binding Cities.NameCity}"  Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,0">
                <Label Content="Логин" Foreground="#FF82DBFF" FontFamily="Arial Black"/>
                <Label Content="Почта" Foreground="#FF82DBFF" FontFamily="Arial Black" Margin="100,0,0,0"/>
                <Label Content="Пароль" Foreground="#FF82DBFF" FontFamily="Arial Black" Margin="180,0,0,0"/>
                <Label Content="Роль" Foreground="#FF82DBFF" FontFamily="Arial Black" Margin="68,0,0,0"/>
                <Label Content="Город" Foreground="#FF82DBFF" FontFamily="Arial Black" Margin="115,0,0,0"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                <TextBox x:Name="UserNameBox" Width="150" Height="30" Margin="0,0,8,0" FontFamily="Arial Black" TabIndex="50" ToolTip="Логин" MaxLength="50" Background="#FF91009A" BorderBrush="#FFE0C14D" Foreground="#FF82DBFF">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <TextBox x:Name="EmailBox" Width="220" Height="30" Margin="0,0,8,0" FontFamily="Arial Black" TabIndex="100" ToolTip="Почта" MaxLength="100" Background="#FF91009A" BorderBrush="#FFE0C14D" Foreground="#FF82DBFF">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <TextBox x:Name="PasswordBox" Width="120" Height="30" Margin="0,0,8,0" FontFamily="Arial Black" TabIndex="50" ToolTip="Пароль" MaxLength="50" Background="#FF91009A" BorderBrush="#FFE0C14D" Foreground="#FF82DBFF">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <ComboBox x:Name="RoleBox" Width="150" Height="30" Margin="0,0,8,0" DisplayMemberPath="NameRole" SelectedValuePath="IdRole" FontFamily="Arial Black">
                    <ComboBox.Resources>
                        <Style TargetType="{x:Type ComboBox}">
                            <Setter Property="Background" Value="#FF91009A"/>
                            <Setter Property="BorderBrush" Value="#FFE0C14D"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Foreground" Value="#FF82DBFF"/>
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ComboBox}">
                                        <Grid>
                                            <Border x:Name="Bd"
        CornerRadius="8"
        Background="{TemplateBinding Background}"
        BorderBrush="{TemplateBinding BorderBrush}"
        BorderThickness="{TemplateBinding BorderThickness}">
                                                <Grid>
                                                    <ContentPresenter Margin="8,0,28,0"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Left"
                          Content="{TemplateBinding SelectionBoxItem}"
                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                                    <ToggleButton Width="24"
                      HorizontalAlignment="Right"
                      Background="Transparent"
                      BorderThickness="0"
                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                                        <Path Data="M 0 0 L 4 4 L 8 0 Z"
                  Fill="White"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"/>
                                                    </ToggleButton>
                                                </Grid>
                                            </Border>

                                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
       Placement="Bottom"
       AllowsTransparency="True"
       Focusable="False">
                                                <Border CornerRadius="8"
            Background="White"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="1"
            MinWidth="{TemplateBinding ActualWidth}">
                                                    <ScrollViewer Margin="4,6,4,6">
                                                        <ItemsPresenter/>
                                                    </ScrollViewer>
                                                </Border>
                                            </Popup>
                                        </Grid>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFEFD36B"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ComboBox.Resources>
                </ComboBox>
                <ComboBox x:Name="CityBox" Width="150" Height="30" Margin="0,0,8,0" DisplayMemberPath="NameCity" SelectedValuePath="IdCity" FontFamily="Arial Black">
                    <ComboBox.Resources>
                        <Style TargetType="{x:Type ComboBox}">
                            <Setter Property="Background" Value="#FF91009A"/>
                            <Setter Property="BorderBrush" Value="#FFE0C14D"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Foreground" Value="#FF82DBFF"/>
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ComboBox}">
                                        <Grid>
                                            <Border x:Name="Bd"
        CornerRadius="8"
        Background="{TemplateBinding Background}"
        BorderBrush="{TemplateBinding BorderBrush}"
        BorderThickness="{TemplateBinding BorderThickness}">
                                                <Grid>
                                                    <ContentPresenter Margin="8,0,28,0"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Left"
                          Content="{TemplateBinding SelectionBoxItem}"
                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                                    <ToggleButton Width="24"
                      HorizontalAlignment="Right"
                      Background="Transparent"
                      BorderThickness="0"
                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                                        <Path Data="M 0 0 L 4 4 L 8 0 Z"
                  Fill="White"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"/>
                                                    </ToggleButton>
                                                </Grid>
                                            </Border>

                                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
       Placement="Bottom"
       AllowsTransparency="True"
       Focusable="False">
                                                <Border CornerRadius="8"
            Background="White"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="1"
            MinWidth="{TemplateBinding ActualWidth}">
                                                    <ScrollViewer Margin="4,6,4,6">
                                                        <ItemsPresenter/>
                                                    </ScrollViewer>
                                                </Border>
                                            </Popup>
                                        </Grid>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFEFD36B"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ComboBox.Resources>
                </ComboBox>
                <Button Content="Сохранить" Width="100" Height="30" Margin="0,0,8,0" Click="EditButton_Click" FontFamily="Arial Black" Foreground="Black" Background="#FFE0C14D"/>
                <Button Content="Удалить" Width="100" Height="30" Margin="0,0,8,0" Click="DeleteButton_Click" FontFamily="Arial Black" Foreground="Black" Background="#FFE0C14D"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
