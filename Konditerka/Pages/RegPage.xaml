<Page x:Class="Konditerka.Pages.RegPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Konditerka.Pages"
      mc:Ignorable="d" d:DesignWidth="800" MinHeight="550"
      Title="RegPage">

    <Grid Background="#FF420046">
        <Label Content="Регистрация" HorizontalAlignment="Center" Margin="0,1,0,0" VerticalAlignment="Top" FontFamily="Arial Black" Foreground="#FF82DBFF" FontSize="36"/>
        <Label Content="Введите логин" HorizontalAlignment="Center" Margin="-110,62,0,0" VerticalAlignment="Top" FontFamily="Arial Black" Foreground="#FF82DBFF" FontSize="20"/>
        <TextBox x:Name="LoginBox" HorizontalAlignment="Center" Margin="0,98,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="274" Height="31" AutomationProperties.Name="LoginBox" TabIndex="50" MaxLength="50" FontFamily="Arial Black" Background="#FF91009A" BorderBrush="#FFE0C14D" Foreground="#FF82DBFF">
            <TextBox.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </TextBox.Resources>
        </TextBox>
        <Label Content="Введите пароль" HorizontalAlignment="Center" Margin="-90,139,0,0" VerticalAlignment="Top" FontFamily="Arial Black" Foreground="#FF82DBFF" FontSize="20"/>
        <PasswordBox x:Name="PassBox" HorizontalAlignment="Center" Margin="0,172,0,0" VerticalAlignment="Top" Width="274" Height="31" AutomationProperties.Name="PassBox" PasswordChanged="PassBox_PasswordChanged" TabIndex="50" MaxLength="50" FontFamily="Arial Black">
            <PasswordBox.Resources>
                <Style TargetType="{x:Type PasswordBox}">
                    <Setter Property="Background" Value="#FF91009A"/>
                    <Setter Property="BorderBrush" Value="#FFE0C14D"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Foreground" Value="#FF82DBFF"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type PasswordBox}">
                                <Border x:Name="Bd"
            CornerRadius="8"
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}">
                                    <ScrollViewer x:Name="PART_ContentHost"
                      Margin="{TemplateBinding Padding}"
                      VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#FFEFD36B"/>
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#FFFFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </PasswordBox.Resources>
        </PasswordBox>
        <Label Content="Подтвердите пароль" HorizontalAlignment="Center" Margin="-40,210,0,0" VerticalAlignment="Top" FontFamily="Arial Black" Foreground="#FF82DBFF" FontSize="20"/>
        <PasswordBox x:Name="PassBoxV" HorizontalAlignment="Center" Margin="0,243,0,0" VerticalAlignment="Top" Width="274" Height="31" AutomationProperties.Name="PassBoxV" PasswordChanged="PassBoxV_PasswordChanged" TabIndex="50" MaxLength="50" FontFamily="Arial Black">
            <PasswordBox.Resources>
                <Style TargetType="{x:Type PasswordBox}">
                    <Setter Property="Background" Value="#FF91009A"/>
                    <Setter Property="BorderBrush" Value="#FFE0C14D"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Foreground" Value="#FF82DBFF"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type PasswordBox}">
                                <Border x:Name="Bd"
            CornerRadius="8"
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}">
                                    <ScrollViewer x:Name="PART_ContentHost"
                      Margin="{TemplateBinding Padding}"
                      VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#FFEFD36B"/>
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#FFFFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </PasswordBox.Resources>
        </PasswordBox>
        <Label Content="Введите почту" HorizontalAlignment="Center" Margin="-110,279,0,0" VerticalAlignment="Top" FontFamily="Arial Black" Foreground="#FF82DBFF" FontSize="20"/>
        <TextBox x:Name="EmailBox" HorizontalAlignment="Center" Margin="0,315,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="274" Height="31" AutomationProperties.Name="EmailBox" TabIndex="100" MaxLength="100" FontFamily="Arial Black" Background="#FF91009A" BorderBrush="#FFE0C14D" Foreground="#FF82DBFF">
            <TextBox.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </TextBox.Resources>
        </TextBox>
        <Button x:Name="AddButton" Content="Зарегистрироватся" HorizontalAlignment="Center" Margin="0,438,0,0" VerticalAlignment="Top" Width="274" Height="37" FontFamily="Arial Black" FontSize="16" Background="#FFE0C14D" Foreground="Black" Click="AddButton_Click" />
        <Button x:Name="GoToAutogizButton" Content="Назад к авторизации" HorizontalAlignment="Center" Margin="0,480,0,0" VerticalAlignment="Top" Width="274" Height="37" FontFamily="Arial Black" FontSize="16" Background="#FFE0C14D" Foreground="Black" Click="GoToAutogizButton_Click"/>
        <Label Content="Выберите город" HorizontalAlignment="Center" Margin="-85,357,0,0" VerticalAlignment="Top" FontFamily="Arial Black" Foreground="#FF82DBFF" FontSize="20"/>
        <ComboBox x:Name="CityBox" HorizontalAlignment="Center" Margin="0,390,0,0" VerticalAlignment="Top" Width="274" Height="31" AutomationProperties.Name="CityBox" TabIndex="100" FontFamily="Arial Black">
            <ComboBox.Resources>
                <Style TargetType="{x:Type ComboBox}">
                    <Setter Property="Background" Value="#FF91009A"/>
                    <Setter Property="BorderBrush" Value="#FFE0C14D"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Foreground" Value="#FF82DBFF"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ComboBox}">
                                <Grid>
                                    <Border x:Name="Bd"
 CornerRadius="8"
 Background="{TemplateBinding Background}"
 BorderBrush="{TemplateBinding BorderBrush}"
 BorderThickness="{TemplateBinding BorderThickness}">
                                        <Grid>
                                            <ContentPresenter Margin="8,0,28,0"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Content="{TemplateBinding SelectionBoxItem}"
                   ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                            <ToggleButton Width="24"
               HorizontalAlignment="Right"
               Background="Transparent"
               BorderThickness="0"
               IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                                <Path Data="M 0 0 L 4 4 L 8 0 Z"
           Fill="White"
           HorizontalAlignment="Center"
           VerticalAlignment="Center"/>
                                            </ToggleButton>
                                        </Grid>
                                    </Border>

                                    <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
Placement="Bottom"
AllowsTransparency="True"
Focusable="False">
                                        <Border CornerRadius="8"
     Background="White"
     BorderBrush="{TemplateBinding BorderBrush}"
     BorderThickness="1"
     MinWidth="{TemplateBinding ActualWidth}">
                                            <ScrollViewer Margin="4,6,4,6">
                                                <ItemsPresenter/>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#FFEFD36B"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ComboBox.Resources>
        </ComboBox>
    </Grid>
</Page>
