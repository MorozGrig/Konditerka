<Page x:Class="Konditerka.Pages.Authoriz"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Konditerka.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Authoriz">

    <Grid Background="#FF420046">
        <Label Content="Авторизация" HorizontalAlignment="Center" Margin="0,28,0,0" VerticalAlignment="Top" FontFamily="Arial Black" Foreground="#FF82DBFF" FontSize="36"/>
        <Label Content="Введите логин" HorizontalAlignment="Center" Margin="-100,120,0,0" VerticalAlignment="Top" FontFamily="Arial Black" Foreground="#FF82DBFF" FontSize="20"/>
        <TextBox x:Name="LoginBox" HorizontalAlignment="Center" Margin="0,156,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="274" Height="31" AutomationProperties.Name="LoginBox" TabIndex="49" FontFamily="Arial Black" UndoLimit="90" MaxLength="50" Background="#FF91009A" BorderBrush="#FFE0C14D" Foreground="#FF82DBFF">
            <TextBox.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </TextBox.Resources>
        </TextBox>
        <Label Content="Введите пароль" HorizontalAlignment="Center" Margin="-90,197,0,0" VerticalAlignment="Top" FontFamily="Arial Black" Foreground="#FF82DBFF" FontSize="20"/>
        <PasswordBox x:Name="PassBox" HorizontalAlignment="Center" Margin="0,230,0,0" VerticalAlignment="Top" Width="274" Height="31" AutomationProperties.Name="PassBox" TabIndex="50" FontFamily="Arial Black" MaxLength="50">
            <PasswordBox.Resources>
                <Style TargetType="{x:Type PasswordBox}">
                    <Setter Property="Background" Value="#FF91009A"/>
                    <Setter Property="BorderBrush" Value="#FFE0C14D"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Foreground" Value="#FF82DBFF"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type PasswordBox}">
                                <Border x:Name="Bd"
                        CornerRadius="8"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="{TemplateBinding Padding}"
                                  VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#FFEFD36B"/>
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#FFFFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </PasswordBox.Resources>
        </PasswordBox>
        <Button x:Name="LoginButton" Content="Войти" HorizontalAlignment="Center" Margin="0,307,0,0" VerticalAlignment="Top" Width="274" Height="37" FontFamily="Arial Black" FontSize="16" Background="#FFE0C14D" Foreground="Black" Click="LoginButton_Click"/>
        <Button x:Name="OpenRegButton" Content="Зарегистрироватся" HorizontalAlignment="Center" Margin="0,349,0,0" VerticalAlignment="Top" Width="274" Height="37" FontFamily="Arial Black" FontSize="16" Background="#FFE0C14D" Foreground="Black" Click="OpenRegButton_Click"/>

    </Grid>
</Page>
