<Page x:Class="Konditerka.Pages.Authoriz"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Konditerka.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Authoriz">

    <Grid Background="#FF420046">
        <Label Content="Авторизация" HorizontalAlignment="Center" Margin="0,28,0,0" VerticalAlignment="Top" FontFamily="Arial Black" Foreground="#FF176B5E" FontSize="36"/>
        <Label Content="Введите логин" HorizontalAlignment="Left" Margin="260,120,0,0" VerticalAlignment="Top" FontFamily="Arial Black" Foreground="#FF176B5E" FontSize="20"/>
        <TextBox x:Name="LoginBox" HorizontalAlignment="Center" Margin="0,156,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="274" Height="31"/>
        <Label Content="Введите пароль" HorizontalAlignment="Left" Margin="261,197,0,0" VerticalAlignment="Top" FontFamily="Arial Black" Foreground="#FF176B5E" FontSize="20"/>
        <PasswordBox x:Name="PassBox" HorizontalAlignment="Center" Margin="0,230,0,0" VerticalAlignment="Top" Width="274" Height="31"/>
        <Button x:Name="LoginButton" Content="Войти" HorizontalAlignment="Center" Margin="0,307,0,0" VerticalAlignment="Top" Width="274" Height="37" FontFamily="Arial Black" FontSize="16" Background="#FFE0C14D" Foreground="#FF176B5E"/>
        <Button x:Name="OpenRegButton" Content="Зарегистрироватся" HorizontalAlignment="Center" Margin="0,349,0,0" VerticalAlignment="Top" Width="274" Height="37" FontFamily="Arial Black" FontSize="16" Background="#FFE0C14D" Foreground="#FF176B5E" Click="Button_Click"/>

    </Grid>
</Page>
