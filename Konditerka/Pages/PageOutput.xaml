<Page x:Class="Konditerka.Pages.PageOutput"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Konditerka.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageOutput">

    <Grid Background="#FF420046">
        <StackPanel x:Name="AddButton" Orientation="Horizontal" VerticalAlignment="Top" Grid.Row="0" Margin="0,14,0,0">
            <ComboBox x:Name="ComboFilter" Margin="5" VerticalAlignment="Center" Width="209" Height="26" SelectionChanged="ComboFilter_SelectionChanged" FontFamily="Arial Black"/>
            <ComboBox x:Name="ComboSort" Margin="5" VerticalAlignment="Top" Width="120" Height="26" SelectionChanged="ComboSort_SelectionChanged" FontFamily="Arial Black"/>
            <TextBox x:Name="TextSearch"  Margin="5" TextWrapping="Wrap" VerticalAlignment="Center" Width="186" Height="26" TextChanged="TextSearch_TextChanged" FontFamily="Arial Black" TabIndex="100"/>
            <Button x:Name="AddProductsButton" Content="Панель администратора" Height="30" Width="200" Click="AddProductsButton_Click" Loaded="AddProductsButton_Loaded" FontFamily="Arial Black" Foreground="#FF176B5E" Background="#FFE0C14D" />
        </StackPanel>

        <ListView x:Name="ListProducts" Margin="0,64,0,79">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="500"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <Border
                                Width="200"
                                Height="200"
                                Margin="3"
                                ClipToBounds="True"
                                Grid.Column="0">
                                <Image Source="{Binding CurrentPhoto}" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Left">
                                <TextBlock Height="auto" Text="{Binding Product}" FontFamily="Arial Black"/>
                                <TextBlock TextWrapping="Wrap" Height="auto" Margin="0,0,0,10" FontFamily="Arial Black"><Run Text="Категория: "/><Run Text=" "/><Run Text="{Binding Categories.NameCategory}"/></TextBlock>
                                <TextBlock TextWrapping="Wrap" Height="auto" Margin="0,0,0,10" FontFamily="Arial Black"><Run Text="Описание: "/><Run Text=" "/><Run Text="{Binding Descripton}"/></TextBlock>
                                <TextBlock TextWrapping="Wrap" Height="auto" Margin="200,0,0,10" FontFamily="Arial Black"><Run Text="Цена: "/><Run Text=" "/><Run Text="{Binding Price}"/></TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <TextBlock x:Name="tbCounter" Height="auto" Margin="0,386,0,0" FontFamily="Arial Black" />
    </Grid>
</Page>
